# ───────────────────────── Kafka ─────────────────────────
# Host-side tools (data generator, topic admin) use the external listener.
# In-container services (Spark) are pointed at kafka:9092 via docker-compose.
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TELEMETRY_TOPIC=iot.telemetry
KAFKA_NUM_PARTITIONS=6

# ───────────────────────── MinIO (S3) ─────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
S3_BUCKET_LAKEHOUSE=lakehouse

# ───────────────────────── PostgreSQL ─────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=metadata
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ───────────────────────── MLflow ─────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ───────────────────────── Airflow ─────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# ───────────────────────── Data generator ─────────────────────────
FLEET_SIZE=500
TELEMETRY_RATE_HZ=5
FAILURE_INJECTION_RATE=0.02
