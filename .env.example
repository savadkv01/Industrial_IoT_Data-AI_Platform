# ───────────────────────── Kafka ─────────────────────────
# Host-side tools (data generator, topic admin) use the external listener.
# In-container services (Spark) are pointed at kafka:9092 via docker-compose.
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TELEMETRY_TOPIC=iot.telemetry
KAFKA_NUM_PARTITIONS=6

# ───────────────────────── MinIO (S3) ─────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
S3_BUCKET_LAKEHOUSE=lakehouse

# ───────────────────────── PostgreSQL ─────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=metadata
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ───────────────────────── MLflow ─────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
# Server-side backend store DB (created by infra/docker/postgres/init.sql) + artifact bucket.
MLFLOW_DB=mlflow
S3_BUCKET_MLFLOW=mlflow
# Registry aliases + promotion gates used by ml.pipeline (Phase 7).
ML_PRODUCTION_ALIAS=production
ML_STAGING_ALIAS=staging
ML_PDM_MIN_AUC=0.85
ML_ANOMALY_MIN_SCORE_AUC=0.60
ML_BATTERY_MAX_RMSE=inf

# ───────────────────────── Airflow ─────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_DB=airflow

# ───────────────────────── Lakehouse (Phase 4) ─────────────────────────
# Data quality gate thresholds (Silver layer)
DQ_MAX_NULL_RATE=0.05
DQ_MAX_RANGE_VIOLATION_RATE=0.01
# Spark shuffle parallelism (tune per cluster size)
SPARK_SHUFFLE_PARTITIONS=8

# ───────────────────────── Feature Engineering (Phase 5) ─────────────────────────
# Optional override; defaults to the Phase 4 Gold Delta path.
FEATURE_GOLD_SOURCE_URI=
# Local Feast/offline-store paths under feature-engineering/
FEATURE_OFFLINE_DIR=data/offline
FEATURE_OFFLINE_FILE=telemetry_features.parquet
FEATURE_FEAST_REGISTRY=feast/data/registry.db
FEATURE_FEAST_ONLINE_STORE=feast/data/online.db

# ───────────────────────── Data generator ─────────────────────────
FLEET_SIZE=500
TELEMETRY_RATE_HZ=5
FAILURE_INJECTION_RATE=0.02
