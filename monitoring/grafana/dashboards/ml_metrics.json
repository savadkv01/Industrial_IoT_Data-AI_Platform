{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["iiot", "phase10", "ml"],
  "title": "ML Metrics & Drift",
  "uid": "iiot-ml-metrics",
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Served Model Versions",
      "type": "table",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "serving_model_version_info", "format": "table", "instant": true, "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 2,
      "title": "Prediction Score (mean over 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(serving_prediction_score_sum[5m])) by (task) / sum(rate(serving_prediction_score_count[5m])) by (task)", "legendFormat": "{{task}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 3,
      "title": "Predictions Scored (per 5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(serving_prediction_score_count[5m])) by (task)", "legendFormat": "{{task}}", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 4,
      "title": "Drift — Share of Drifted Features",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Pushed by the drift_report DAG (requires the Prometheus pushgateway). Falls back to 'No data' until the first run.",
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.25 },
            { "color": "red", "value": 0.5 }
          ] }
        }
      },
      "targets": [
        { "expr": "iiot_drift_share", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 5,
      "title": "Drift — Dataset Drift Flag",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STABLE", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DRIFT", "color": "red" } } }
          ]
        }
      },
      "targets": [
        { "expr": "iiot_dataset_drift", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6,
      "title": "Drift — Features Drifted",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "iiot_drift_features_drifted", "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
