{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["iiot", "phase10", "bi", "gold"],
  "title": "Fleet Operations (BI)",
  "uid": "iiot-fleet-bi",
  "timezone": "browser",
  "time": { "from": "now-30d", "to": "now" },
  "refresh": "5m",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Machines",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "analytics-pg" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^n_machines$/", "values": false } },
      "targets": [
        { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT n_machines FROM analytics.fleet_kpis LIMIT 1;", "datasource": { "type": "postgres", "uid": "analytics-pg" } }
      ]
    },
    {
      "id": 2,
      "title": "Failure Rate",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "analytics-pg" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.15 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^failure_rate$/", "values": false } },
      "targets": [
        { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT failure_rate FROM analytics.fleet_kpis LIMIT 1;", "datasource": { "type": "postgres", "uid": "analytics-pg" } }
      ]
    },
    {
      "id": 3,
      "title": "Avg Battery SoH",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "analytics-pg" },
      "fieldConfig": { "defaults": { "decimals": 3, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.8 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^avg_battery_soh$/", "values": false } },
      "targets": [
        { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT avg_battery_soh FROM analytics.fleet_kpis LIMIT 1;", "datasource": { "type": "postgres", "uid": "analytics-pg" } }
      ]
    },
    {
      "id": 4,
      "title": "Total Errors",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "analytics-pg" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^total_errors$/", "values": false } },
      "targets": [
        { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT total_errors FROM analytics.fleet_kpis LIMIT 1;", "datasource": { "type": "postgres", "uid": "analytics-pg" } }
      ]
    },
    {
      "id": 5,
      "title": "Fleet Avg Vibration (1h windows)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "postgres", "uid": "analytics-pg" },
      "targets": [
        { "refId": "A", "format": "time_series", "rawQuery": true, "rawSql": "SELECT window_end AS \"time\", AVG(vibration_mean) AS avg_vibration, MAX(vibration_max) AS max_vibration FROM analytics.gold_features WHERE window_duration = '1h' GROUP BY 1 ORDER BY 1;", "datasource": { "type": "postgres", "uid": "analytics-pg" } }
      ]
    },
    {
      "id": 6,
      "title": "Fleet Avg Battery SoH (1h windows)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "postgres", "uid": "analytics-pg" },
      "fieldConfig": { "defaults": { "decimals": 3 } },
      "targets": [
        { "refId": "A", "format": "time_series", "rawQuery": true, "rawSql": "SELECT window_end AS \"time\", AVG(battery_soh_mean) AS avg_battery_soh, MIN(battery_soh_min) AS min_battery_soh FROM analytics.gold_features WHERE window_duration = '1h' GROUP BY 1 ORDER BY 1;", "datasource": { "type": "postgres", "uid": "analytics-pg" } }
      ]
    },
    {
      "id": 7,
      "title": "Machine Health (latest 5m window)",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "postgres", "uid": "analytics-pg" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "battery_soh_mean" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.8 } ] } }, { "id": "decimals", "value": 3 } ] },
          { "matcher": { "id": "byName", "options": "failure_label" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "true": { "text": "FAIL", "color": "red" }, "false": { "text": "ok", "color": "green" } } } ] } ] }
        ]
      },
      "targets": [
        { "refId": "A", "format": "table", "rawQuery": true, "rawSql": "SELECT machine_id, last_window_end, battery_soh_mean, vibration_mean, vibration_max, motor_temp_mean, error_count, failure_label FROM analytics.machine_health ORDER BY battery_soh_mean ASC NULLS FIRST;", "datasource": { "type": "postgres", "uid": "analytics-pg" } }
      ]
    }
  ]
}
