# Normalize line endings across platforms to avoid churn.
* text=auto eol=lf

# Windows-specific scripts keep CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.parquet binary
*.pkl   binary
*.joblib binary
*.pt    binary
